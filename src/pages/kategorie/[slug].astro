---
// src/pages/kategorie/[slug].astro
import Layout from '../../layouts/Layout.astro';
import { posts, categories, getCatMap, img, media as mediaItems } from '../../data/index.js';

const catMap = getCatMap();
const catBySlug = {};
categories.forEach(c => { catBySlug[c.slug] = c; });

export async function getStaticPaths() {
  return categories
    .filter(c => c.slug !== 'allgemein' && c.slug !== 'uncategorized')
    .map(cat => ({
      params: { slug: cat.slug },
      props: { category: cat }
    }));
}

const { category } = Astro.props;
const catPosts = posts
  .filter(p => p.categories?.includes(category.id))
  .sort((a, b) => new Date(b.date) - new Date(a.date));

function formatDate(dateStr) {
  return new Date(dateStr).toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title={category.name} description={category.description || `Alle Beiträge aus der Kategorie ${category.name} auf Doggi-Dog.`}>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <nav class="text-sm text-[var(--color-text-muted)] mb-6">
      <a href="/" class="hover:text-[var(--color-primary)]">Home</a>
      <span class="mx-2">›</span>
      <span class="text-[var(--color-text)]">{category.name}</span>
    </nav>

    <h1 class="section-title">{category.name}</h1>
    {category.description && (
      <p class="text-center text-[var(--color-text-muted)] max-w-2xl mx-auto mb-12">{category.description}</p>
    )}

    {catPosts.length === 0 ? (
      <div class="text-center py-12">
        <p class="text-[var(--color-text-muted)]">In dieser Kategorie gibt es noch keine Beiträge.</p>
        <a href="/blog/" class="text-[var(--color-primary)] font-semibold hover:underline mt-4 inline-block">Alle Blog-Beiträge anzeigen →</a>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {catPosts.map(post => {
          const excerpt = post.excerpt?.rendered?.replace(/<[^>]+>/g, '').trim() || '';
          const postImgSrc = post.featured_media ? img(post.featured_media) : null;
          const postImgMeta = post.featured_media ? mediaItems.find(m => m.id === post.featured_media) : null;
          return (
            <article class="card">
              <a href={`/blog/${post.slug}/`}>
                <div class="aspect-video overflow-hidden bg-orange-100">
                  {postImgSrc ? (
                    <img src={postImgSrc} alt={postImgMeta?.alt_text || post.title?.rendered || ''} class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" loading="lazy" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center">
                      <span class="text-4xl opacity-50">🐶</span>
                    </div>
                  )}
                </div>
              </a>
              <div class="p-5">
                <h2>
                  <a href={`/blog/${post.slug}/`}
                    class="font-bold text-[var(--color-text)] hover:text-[var(--color-primary)] transition-colors">
                    {post.title?.rendered || post.title}
                  </a>
                </h2>
                <p class="text-sm text-[var(--color-text-muted)] mt-2 line-clamp-2">{excerpt}</p>
                <div class="flex justify-between items-center mt-3 pt-2 border-t border-gray-100">
                  <time class="text-xs text-[var(--color-text-muted)]">{formatDate(post.date)}</time>
                  <a href={`/blog/${post.slug}/`} class="text-sm text-[var(--color-primary)] hover:underline">mehr →</a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )}
  </div>
</Layout>
